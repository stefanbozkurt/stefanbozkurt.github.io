{
  "name": "stefanbozkurt.github.io",
  "version": "1.0.0",
  "scripts": {
    "build": "npm run minify-js && npm run minify-css && npm run copy-html",
    "watch": "npm-run-all --parallel watch:scss watch:js watch:html",
    "watch:scss": "sass --watch src/css/styles.scss:dist/css/styles.min.css --style compressed --no-source-map",
    "watch:js": "npx chokidar 'src/js/*.js' -c 'npm run minify-js'",
    "watch:html": "npx chokidar 'src/index.html' -c 'npm run copy-html'",
    "minify-js": "terser src/js/*.js --compress --mangle --output dist/js/main.min.js",
    "minify-css": "cleancss -o dist/css/styles.min.css src/css/*.css",
    "copy-html": "copyfiles -u 1 src/index.html dist/",
    "serve": "browser-sync start --server 'dist' --files 'dist/**/*'"
  },
  "devDependencies": {
    "browser-sync": "^3.0.3",
    "chokidar": "^4.0.1",
    "clean-css-cli": "^5.6.3",
    "copyfiles": "^2.4.1",
    "http-server": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "sass": "^1.47.0",
    "terser": "^5.36.0"
  }
}
