{
  "name": "stefanbozkurt.github.io",
  "version": "1.0.0",
  "scripts": {
    "watch": "npm-run-all --parallel watch:scss watch:js",
    "watch:scss": "npx sass --watch src/css/styles.scss:dist/css/styles.min.css --style compressed --no-source-map",
    "watch:js": "npx chokidar 'src/js/*.js' -c 'npm run minify-js'",
    "build": "npm run minify-js && npm run minify-css",
    "minify-js": "terser src/js/*.js --compress --mangle --output dist/js/main.min.js",
    "minify-css": "cleancss -o dist/css/styles.min.css src/css/*.css"
  },
  "devDependencies": {
    "chokidar": "^4.0.1",
    "clean-css-cli": "^5.6.3",
    "copyfiles": "^2.4.1",
    "terser": "^5.36.0",
    "sass": "^1.47.0",
    "npm-run-all": "^4.1.5"
  }
}
